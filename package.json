{
  "private": true,
  "name": "medi-agent",
  "description": "Root package — only holds dev tooling (Husky, lint-staged)",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.3.0"
  },
  "lint-staged": {
    "backend/src/**/*.py": [
      "ruff check --fix --unsafe-fixes",
      "ruff format",
      "mypy --ignore-missing-imports"
    ],
    "apps/**/*.{ts,tsx}": [
      "bash -c 'cd apps/patient-portal && ./node_modules/.bin/eslint --fix \"$0\"'"
    ]
  }
}
