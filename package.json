{
  "private": true,
  "name": "medi-agent",
  "description": "Root package — only holds dev tooling (Husky, lint-staged)",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.3.0"
  },
  "lint-staged": {
    "backend/src/**/*.py": [
      "ruff check --fix",
      "ruff format"
    ],
    "apps/**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
