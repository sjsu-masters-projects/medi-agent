# ============================================================
# MediAgent — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --------------- Supabase ---------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --------------- Google / Gemini ---------------
GOOGLE_API_KEY=
GOOGLE_PROJECT_ID=

# --------------- MedGemma (optional — after evaluation) ---------------
# MEDGEMMA_MODEL_ID=

# --------------- Deepgram ---------------
DEEPGRAM_API_KEY=

# --------------- Resend (email) ---------------
RESEND_API_KEY=

# --------------- Syncfusion ---------------
SYNCFUSION_LICENSE_KEY=

# --------------- App URLs ---------------
BACKEND_URL=http://localhost:8000
PATIENT_PORTAL_URL=http://localhost:3000
CLINICIAN_PORTAL_URL=http://localhost:3001

# --------------- Runtime ---------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG
