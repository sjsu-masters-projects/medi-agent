# ============================================================
# MediAgent — Environment Variables
#
# HOW TO USE:
#   1. Copy to .env:  cp .env.example .env
#   2. Fill in values from the team's 1Password vault (or ask the team lead)
#   3. NEVER commit .env — it's in .gitignore
#
# KEEPING IN SYNC:
#   - When adding a new env var, add it HERE with a comment.
#   - The backend's config.py validates all required vars on startup.
#   - The check-env.sh script (below) catches missing vars before you
#     waste time debugging.
#
# QUICK CHECK:
#   ./scripts/check-env.sh
# ============================================================

# --------------- Supabase ---------------
# Dashboard → Settings → API
SUPABASE_URL=https://tsbjrzlzrejzlfkmhxpz.supabase.co
SUPABASE_ANON_KEY=               # "anon" "public" key
SUPABASE_SERVICE_ROLE_KEY=       # secret — never expose to frontend
SUPABASE_JWT_SECRET=             # Dashboard → Settings → API → JWT Secret

# --------------- Google / Gemini ---------------
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_PROJECT_ID=               # only needed for Vertex AI

# --------------- MedGemma (optional — after evaluation) ---------------
# MEDGEMMA_MODEL_ID=

# --------------- Deepgram ---------------
# https://console.deepgram.com
DEEPGRAM_API_KEY=

# --------------- Resend (email) ---------------
# https://resend.com/api-keys
RESEND_API_KEY=

# --------------- Syncfusion ---------------
# https://www.syncfusion.com/account/manage-licenses
SYNCFUSION_LICENSE_KEY=

# --------------- App URLs ---------------
BACKEND_URL=http://localhost:8000
PATIENT_PORTAL_URL=http://localhost:3000
CLINICIAN_PORTAL_URL=http://localhost:3001

# --------------- Runtime ---------------
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=DEBUG                  # DEBUG | INFO | WARNING | ERROR
